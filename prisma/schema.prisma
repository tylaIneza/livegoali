generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  EDITOR
  ADMIN
  SUPER_ADMIN
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  FINISHED
  POSTPONED
  CANCELLED
}

enum StreamType {
  HLS
  DASH
  MP4
  IFRAME
}

enum PredictionOutcome {
  HOME_WIN
  DRAW
  AWAY_WIN
}

enum AdPlacement {
  HEADER
  SIDEBAR
  FOOTER
  IN_PLAYER
  VIDEO
  POPUP
  SPONSORED
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?   @db.Text
  password      String?
  role          UserRole  @default(USER)
  isVIP         Boolean   @default(false)
  isBanned      Boolean   @default(false)
  banReason     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  predictions     PredictionEntry[]
  comments        Comment[]
  chatMessages    LiveChatMessage[]
  favorites       Favorite[]
  notifications   Notification[]
  vipSubscription VIPSubscription?
  auditLogs       AuditLog[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Sport {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  icon         String   @default("🏆")
  enabled      Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  matches Match[]

  @@index([slug])
  @@index([enabled])
}

model League {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  country    String
  logo       String?  @db.Text
  season     String
  isActive   Boolean  @default(true)
  isFeatured Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  matches   Match[]
  teams     Team[]
  standings Standing[]
  favorites Favorite[]

  @@index([slug])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  shortName String?
  logo      String?  @db.Text
  stadium   String?
  city      String?
  country   String?
  coach     String?
  founded   Int?
  website   String?
  leagueId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  league      League?    @relation(fields: [leagueId], references: [id])
  homeMatches Match[]    @relation("HomeTeam")
  awayMatches Match[]    @relation("AwayTeam")
  players     Player[]
  standings   Standing[]
  favorites   Favorite[]

  @@index([slug])
  @@index([leagueId])
}

model Player {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  position    String?
  nationality String?
  dateOfBirth DateTime?
  number      Int?
  image       String?   @db.Text
  marketValue Float?
  teamId      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  team    Team?          @relation(fields: [teamId], references: [id])
  lineups LineupPlayer[]

  @@index([slug])
  @@index([teamId])
}

model Match {
  id               String      @id @default(cuid())
  slug             String      @unique
  sportId          String?
  leagueId         String?
  homeTeamId       String?
  awayTeamId       String?
  title            String?
  participant1     String?
  participant2     String?
  streamUrl        String?     @db.Text
  streamType       String      @default("IFRAME")
  streamQuality    String      @default("HD")
  metadata         String?     @db.Text
  homeScore        Int?        @default(0)
  awayScore        Int?        @default(0)
  homeHalfScore    Int?
  awayHalfScore    Int?
  status           MatchStatus @default(SCHEDULED)
  matchMinute      Int?
  scheduledAt      DateTime
  startedAt        DateTime?
  endedAt          DateTime?
  venue            String?
  referee          String?
  attendance       Int?
  coverImage       String?     @db.Text
  isFeatured       Boolean     @default(false)
  enableComments   Boolean     @default(true)
  enableChat       Boolean     @default(true)
  enablePrediction Boolean     @default(true)
  round            String?
  season           String?
  views            Int         @default(0)
  userViews        Int         @default(0)
  anonViews        Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  sport             Sport?            @relation(fields: [sportId], references: [id])
  league            League?           @relation(fields: [leagueId], references: [id])
  homeTeam          Team?             @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam          Team?             @relation("AwayTeam", fields: [awayTeamId], references: [id])
  streams           StreamSource[]
  statistics        MatchStatistic?
  lineups           Lineup[]
  events            MatchEvent[]
  comments          Comment[]
  chatMessages      LiveChatMessage[]
  prediction        Prediction?
  predictionEntries PredictionEntry[]

  @@index([slug])
  @@index([sportId])
  @@index([leagueId])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([status])
  @@index([scheduledAt])
}

model StreamSource {
  id        String     @id @default(cuid())
  matchId   String
  url       String     @db.Text
  type      StreamType @default(HLS)
  quality   String     @default("HD")
  isPrimary Boolean    @default(false)
  isActive  Boolean    @default(true)
  priority  Int        @default(1)
  label     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}

model MatchStatistic {
  id                String   @id @default(cuid())
  matchId           String   @unique
  homePossession    Float?
  awayPossession    Float?
  homeShots         Int?
  awayShots         Int?
  homeShotsOnTarget Int?
  awayShotsOnTarget Int?
  homeCorners       Int?
  awayCorners       Int?
  homeYellowCards   Int?
  awayYellowCards   Int?
  homeRedCards      Int?
  awayRedCards      Int?
  homeOffsides      Int?
  awayOffsides      Int?
  homeFouls         Int?
  awayFouls         Int?
  homePassAccuracy  Float?
  awayPassAccuracy  Float?
  homeXG            Float?
  awayXG            Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Lineup {
  id        String  @id @default(cuid())
  matchId   String
  teamId    String
  formation String?
  coach     String?
  isHome    Boolean

  match   Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  players LineupPlayer[]

  @@unique([matchId, teamId])
  @@index([matchId])
}

model LineupPlayer {
  id        String  @id @default(cuid())
  lineupId  String
  playerId  String
  isStarter Boolean @default(true)
  position  String?
  number    Int?

  lineup Lineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@index([lineupId])
}

model MatchEvent {
  id          String   @id @default(cuid())
  matchId     String
  type        String
  minute      Int
  playerName  String?
  teamId      String?
  description String?
  createdAt   DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
}

model Prediction {
  id                String             @id @default(cuid())
  matchId           String             @unique
  homeWinProb       Float
  drawProb          Float
  awayWinProb       Float
  expectedHomeGoals Float?
  expectedAwayGoals Float?
  confidence        Float
  aiExplanation     String?            @db.Text
  expertAnalysis    String?            @db.Text
  recommendation    PredictionOutcome?
  isOverridden      Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model PredictionEntry {
  id                 String            @id @default(cuid())
  userId             String
  matchId            String
  outcome            PredictionOutcome
  predictedHomeScore Int?
  predictedAwayScore Int?
  firstScorerId      String?
  overUnder          String?
  btts               Boolean?
  points             Int               @default(0)
  isCorrect          Boolean?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  matchId   String
  parentId  String?
  likes     Int      @default(0)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  match   Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  @@index([matchId])
  @@index([userId])
  @@index([parentId])
}

model LiveChatMessage {
  id        String   @id @default(cuid())
  content   String
  userId    String
  matchId   String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([userId])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  news News[]
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  news NewsTag[]
}

model News {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  excerpt        String?   @db.Text
  content        String    @db.Text
  featuredImage  String?   @db.Text
  categoryId     String?
  isPublished    Boolean   @default(false)
  isFeatured     Boolean   @default(false)
  isSponsored    Boolean   @default(false)
  views          Int       @default(0)
  seoTitle       String?
  seoDescription String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  publishedAt    DateTime?

  category Category? @relation(fields: [categoryId], references: [id])
  tags     NewsTag[]

  @@index([slug])
  @@index([categoryId])
  @@index([isPublished])
}

model NewsTag {
  newsId String
  tagId  String

  news News @relation(fields: [newsId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([newsId, tagId])
}

model Standing {
  id             String   @id @default(cuid())
  leagueId       String
  teamId         String
  season         String
  position       Int
  played         Int      @default(0)
  won            Int      @default(0)
  drawn          Int      @default(0)
  lost           Int      @default(0)
  goalsFor       Int      @default(0)
  goalsAgainst   Int      @default(0)
  goalDifference Int      @default(0)
  points         Int      @default(0)
  form           String?
  updatedAt      DateTime @updatedAt

  league League @relation(fields: [leagueId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([leagueId, teamId, season])
  @@index([leagueId])
  @@index([teamId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  teamId    String?
  leagueId  String?
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team?   @relation(fields: [teamId], references: [id])
  league League? @relation(fields: [leagueId], references: [id])

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model Advertisement {
  id        String      @id @default(cuid())
  title     String
  imageUrl  String?     @db.Text
  videoUrl  String?     @db.Text
  targetUrl String      @db.Text
  placement AdPlacement
  isActive  Boolean     @default(true)
  startDate DateTime?
  endDate   DateTime?
  views     Int         @default(0)
  clicks    Int         @default(0)
  revenue   Float       @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([placement])
  @@index([isActive])
}

model VIPSubscription {
  id        String             @id @default(cuid())
  userId    String             @unique
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime
  amount    Float
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  details   String?  @db.Text
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity])
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
