  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:socket": "tsx --env-file=.env.local src/server/socket.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:socket\"",
    "build": "prisma generate && next build",
